{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Insurance Service",
  "description": "Схема для представления кредитного продукта",
  "type": "object",
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "href",
        "method",
        "rel"
      ],
      "properties": {
        "href": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^https://example.com/api/v1/credit_products/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
            },
            {
              "type": "string",
              "pattern": "^https://example.com/api/v1/insurance_contract/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
            },
            {
              "type": "string",
              "pattern": "^https://example.com/api/v1/borrower/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
            },
            {
              "type": "string",
              "pattern": "^https://example.com/api/v1/payment/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
            }
          ]
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PATCH",
            "DELETE"
          ]
        },
        "rel": {
          "type": "string"
        }
      }
    },
    "credit_product_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "self",
        "credit_products",
        "borrower",
        "insurance_contracts"
      ],
      "properties": {
        "self": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "self"
                }
              }
            }
          ]
        },
        "credit_products": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "credit_products"
                }
              }
            }
          ]
        },
        "borrower": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "borrower"
                }
              }
            }
          ]
        },
        "insurance_contracts": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "insurance_contracts"
                }
              }
            }
          ]
        }
      }
    },
    "insurance_contract_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "self",
        "insurance_contracts",
        "status",
        "credit_product",
        "borrower",
        "payments",
        "create",
        "update",
        "delete"
      ],
      "properties": {
        "self": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "self"
                }
              }
            }
          ]
        },
        "insurance_contracts": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "insurance_contracts"
                }
              }
            }
          ]
        },
        "status": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "status"
                }
              }
            }
          ]
        },
        "credit_product": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "credit_product"
                }
              }
            }
          ]
        },
        "borrower": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "borrower"
                }
              }
            }
          ]
        },
        "payments": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "payments"
                }
              }
            }
          ]
        },
        "create": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "POST"
                },
                "rel": {
                  "const": "create"
                }
              }
            }
          ]
        },
        "update": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "PATCH"
                },
                "rel": {
                  "const": "update"
                }
              }
            }
          ]
        },
        "delete": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "DELETE"
                },
                "rel": {
                  "const": "delete"
                }
              }
            }
          ]
        }
      }
    },
    "borrower_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "self",
        "borrowers",
        "create",
        "update",
        "delete"
      ],
      "properties": {
        "self": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "self"
                }
              }
            }
          ]
        },
        "borrowers": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "borrowers"
                }
              }
            }
          ]
        },
        "create": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "POST"
                },
                "rel": {
                  "const": "create"
                }
              }
            }
          ]
        },
        "update": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "PATCH"
                },
                "rel": {
                  "const": "update"
                }
              }
            }
          ]
        },
        "delete": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "DELETE"
                },
                "rel": {
                  "const": "delete"
                }
              }
            }
          ]
        }
      }
    },
    "payment_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "self",
        "payments",
        "status",
        "insurance_contract",
        "create"
      ],
      "properties": {
        "self": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "self"
                }
              }
            }
          ]
        },
        "payments": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "payments"
                }
              }
            }
          ]
        },
        "status": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "status"
                }
              }
            }
          ]
        },
        "insurance_contract": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "GET"
                },
                "rel": {
                  "const": "insurance_contract"
                }
              }
            }
          ]
        },
        "create": {
          "allOf": [
            {
              "$ref": "#/$defs/link"
            },
            {
              "properties": {
                "method": {
                  "const": "POST"
                },
                "rel": {
                  "const": "create"
                }
              }
            }
          ]
        }
      }
    },
    "credit_product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credit_product_id",
        "product_name",
        "product_type",
        "credit_product_status",
        "loan_amount",
        "current_loan_amount",
        "loan_length",
        "interest_rate",
        "payment_frequency",
        "insure_status",
        "borrow_id",
        "loan_created_at"
      ],
      "properties": {
        "credit_product_id": {
          "type": "string",
          "format": "uuid"
        },
        "product_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "product_type": {
          "type": "string",
          "enum": [
            "Кредит физическим лицам",
            "Кредит юридическим лицам",
            "Межбанковский кредит",
            "Государственный кредит"
          ]
        },
        "credit_product_status": {
          "type": "string",
          "enum": [
            "активный",
            "архивный"
          ]
        },
        "loan_amount": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000000000,
          "multipleOf": 0.01
        },
        "current_loan_amount": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000000000,
          "multipleOf": 0.01
        },
        "loan_length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "interest_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "payment_frequency": {
          "type": "string",
          "enum": [
            "ежемесячно",
            "ежегодно"
          ]
        },
        "insure_status": {
          "type": "string",
          "enum": [
            "нет страховки",
            "есть страховка"
          ]
        },
        "borrow_id": {
          "type": "string",
          "format": "uuid"
        },
        "loan_created_at": {
          "type": "string",
          "format": "date-time"
        },
        "_links": {
          "$ref": "#/$defs/credit_product_links"
        }
      }
    },
    "insurance_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "credit_product_id",
        "borrow_id",
        "insurance_type",
        "insurance_level",
        "insurance_details",
        "payment_status",
        "_links"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "format": "uuid"
        },
        "credit_product_id": {
          "type": "string",
          "format": "uuid"
        },
        "borrow_id": {
          "type": "string",
          "format": "uuid"
        },
        "insurance_type": {
          "type": "string",
          "enum": [
            "инвестиционное страхование",
            "страхование с залогом"
          ]
        },
        "insurance_level": {
          "type": "string",
          "enum": [
            "полное страхование",
            "базовое страхование"
          ]
        },
        "insurance_details": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "payment_status": {
          "type": "string",
          "enum": [
            "pending",
            "processing",
            "completed",
            "failed"
          ]
        },
        "_links": {
          "$ref": "#/$defs/insurance_contract_links"
        }
      }
    },
    "borrower": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "borrow_id",
        "age",
        "monthly_income",
        "employment_status",
        "_links"
      ],
      "properties": {
        "borrow_id": {
          "type": "string",
          "format": "uuid"
        },
        "age": {
          "type": "integer",
          "minimum": 18,
          "maximum": 100
        },
        "monthly_income": {
          "type": "number",
          "minimum": 0,
          "maximum": 100000000
        },
        "employment_status": {
          "type": "string",
          "enum": [
            "трудоустроен",
            "самозанятый",
            "безработный"
          ]
        },
        "_links": {
          "$ref": "#/$defs/borrower_links"
        }
      }
    },
    "payment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payment_id",
        "insurance_contract_id",
        "payment_details",
        "payment_sum",
        "currency",
        "paid_at",
        "_links"
      ],
      "properties": {
        "payment_id": {
          "type": "string",
          "format": "uuid"
        },
        "insurance_contract_id": {
          "type": "string",
          "format": "uuid"
        },
        "payment_details": {
          "type": "string",
          "minLength": 12,
          "maxLength": 12
        },
        "payment_sum": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000000
        },
        "currency": {
          "type": "string",
          "enum": [
            "рубль",
            "евро",
            "доллар"
          ]
        },
        "paid_at": {
          "type": "string",
          "format": "date-time"
        },
        "_links": {
          "$ref": "#/$defs/payment_links"
        }
      }
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/credit_product"
    },
    {
      "$ref": "#/$defs/insurance_contract"
    },
    {
      "$ref": "#/$defs/borrower"
    },
    {
      "$ref": "#/$defs/payment"
    }
  ]
}