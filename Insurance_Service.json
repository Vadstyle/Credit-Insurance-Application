{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Кредитный продукт",
  "description": "Схема для представления кредитного продукта (ответ GET /api/v1/credit_products/{credit_product_id})",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credit_product_id",
    "product_name",
    "product_type",
    "credit_product_status",
    "loan_amount",
    "current_loan_amount",
    "loan_length",
    "interest_rate",
    "payment_frequency",
    "insure_status",
    "borrow_id",
    "loan_created_at",
    "_links"
  ],
  "properties": {
    "credit_product_id": {
    "type": "string",
    "format": "uuid",
    "description": "Уникальный идентификатор кредитного продукта",
    "minLength": 36,
    "maxLength": 36
    },
  "product_name": {
    "type": "string",
    "description": "Название продукта",
    "minLength": 1,
    "maxLength": 100
    },
  "product_type": {
    "type": "string",
    "description": "Тип кредитного продукта",
    "enum": [
      "Кредит физическим лицам",
      "Кредит юридическим лицам",
      "Межбанковский кредит",
      "Государственный кредит"
      ]
    },
  "credit_product_status": {
    "type": "string",
    "description": "Статус продукта",
    "enum": [
    "активный",
    "архивный"
      ]
    },
  "loan_amount": {
    "type": "number",
    "description": "Сумма кредита",
    "minimum": 1,
    "maximum": 1000000000,
    "multipleOf": 0.01
    },
  "current_loan_amount": {
    "type": "number",
    "description": "Оставшаяся сумма кредита",
    "minimum": 0,
    "maximum": 1000000000,
    "multipleOf": 0.01
    },
  "loan_length": {
    "type": "integer",
    "description": "Срок кредита в месяцах",
    "minimum": 1,
    "maximum": 600
    },
  "interest_rate": {
    "type": "number",
    "description": "Годовая ставка в процентах",
    "minimum": 0,
    "maximum": 100,
    "multipleOf": 0.01
    },
  "payment_frequency": {
    "type": "string",
    "description": "Частота платежей",
    "enum": [
      "ежемесячно",
      "ежегодно"
      ]
    },
  "insure_status": {
    "type": "string",
    "description": "Статус страхования",
    "enum": [
      "нет страховки",
      "есть страховка"
      ]
    },
  "borrow_id": {
    "type": "string",
    "format": "uuid",
    "description": "Уникальный идентификатор заемщика",
    "minLength": 36,
    "maxLength": 36
    },
  "loan_created_at": {
    "type": "string",
    "format": "date-time",
    "description": "Дата и время оформления кредита"
    },
    "_links": {
  "$ref": "#/components/schemas/Links"
    }
  }
}